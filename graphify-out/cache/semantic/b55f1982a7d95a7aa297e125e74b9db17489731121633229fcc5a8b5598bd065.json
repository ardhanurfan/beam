{"nodes": [{"id": "docs_prd_overview", "label": "PRD: Beam Product Vision", "file_type": "document", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core architectural principle: compute and data stay 100% on the local laptop; the app only projects laptop state to the phone over an encrypted tunnel."}, {"id": "docs_prd_problem_statement", "label": "Problem Statement", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_prd_competitive_positioning", "label": "Competitive Positioning (vs 9remote / cloud)", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_prd_value_proposition", "label": "Value Proposition", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_prd_system_topology", "label": "System Topology (One-Way Trust Path)", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "cloudflared makes an outbound-only connection from the laptop to the Cloudflare edge, so no public port is ever opened, eliminating the port-scanning attack class entirely."}, {"id": "docs_prd_main_components", "label": "Main Components Table", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_prd_data_channel_spec", "label": "Data Channel Specification (WSS envelope)", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every WebSocket frame uses a structured JSON envelope (type/sessionId/seq/timestamp/payload) instead of a raw string so the frontend can distinguish payload types without heuristics, and seq drives loss detection + resync."}, {"id": "docs_prd_security_protocol", "label": "Security Protocol (Cloudflare Access Policy)", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Blocking happens at the edge network, before a request ever reaches the laptop; app-layer checks (sessionId validation, optional command allowlist) are a second layer, not a replacement."}, {"id": "docs_prd_fr_agent_interaction", "label": "FR-3.1 Agent Interaction Surface", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "v1.1 revision note: parsing Claude Code's TUI into chat bubbles fragmented badly in field testing, so the shipped implementation renders a real xterm.js terminal instead of the originally specified chat-parser (FR-3.1.2-5 superseded)."}, {"id": "docs_prd_fr_git_review", "label": "FR-3.2 Mobile Visual Git Review & Panic Buttons", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_prd_fr_file_explorer", "label": "FR-3.3 File Explorer & Mini-Editor", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_prd_fr_workspace", "label": "FR-3.4 VSCode Multi-Root Workspace Support", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cross-repo git status aggregation and workspace settings.json inheritance are deliberately deferred (not dropped) to keep the simple version scoped."}, {"id": "docs_prd_persistence", "label": "Section 4: Persistence & Daemon State Management", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Detach-don't-kill: a PTY session is owned by a server-side process manager independent of any WebSocket connection, so a heavy agent task never dies just because the phone's connection dropped."}, {"id": "docs_prd_scope_roadmap", "label": "Scope & Development Roadmap", "file_type": "concept", "source_file": "docs/PRD.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Embedded Live Preview was removed from the active roadmap (not merely deferred) to protect focus on the core phone workflow (terminal/git/files) until that is genuinely viable."}], "edges": [{"source": "docs_prd_system_topology", "target": "readme_cloudflare_access", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/PRD.md", "source_location": null, "weight": 1.0}, {"source": "docs_prd_system_topology", "target": "readme_cloudflare_tunnel", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/PRD.md", "source_location": null, "weight": 1.0}, {"source": "docs_prd_fr_agent_interaction", "target": "docs_design_components", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "docs/PRD.md", "source_location": null, "weight": 1.0}, {"source": "docs_prd_fr_agent_interaction", "target": "api_fs_write", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/PRD.md", "source_location": null, "weight": 1.0}, {"source": "docs_prd_fr_file_explorer", "target": "api_fs_write", "relation": "refer