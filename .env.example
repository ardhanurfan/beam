# Beam server configuration.
# Copy to .env (or export in your shell) and adjust as needed.
# All variables are optional — the defaults below are what Beam uses.

# Local server port (HTTP + WebSocket /ws). The Cloudflare Tunnel ingress
# must point at this port (see docs/DEPLOYMENT.md).
PORT=2424

# Shell or binary spawned for each PTY session.
# Defaults to your login shell ($SHELL). Point it at a specific shell or
# directly at an agent binary if desired.
# MMC_SHELL=/bin/zsh

# Hours a dormant session (no connected phone) may live before the PTY is
# terminated. Keeps abandoned sessions from leaking laptop resources.
MMC_IDLE_HOURS=12

# Contact identity (mailto: or https:) sent to the browser push service with
# every Web Push notification, as required by the VAPID spec. Set it to your
# own address; some push services reject placeholder subjects.
# MMC_PUSH_SUBJECT=mailto:you@example.com

# Jira integration (Tasks tab). The Jira subtab only appears when ALL THREE
# are set. The token never leaves the laptop — every request is proxied
# through the server. Create a token at id.atlassian.com → Security →
# API tokens.
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=your-api-token
